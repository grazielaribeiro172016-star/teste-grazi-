# ═══════════════════════════════════════════════════════════════
#  FORTUNA DO TIGRE — Variáveis de Ambiente
#  Renomeie para .env.local (NUNCA suba para o GitHub)
#  Na Vercel: Settings → Environment Variables
# ═══════════════════════════════════════════════════════════════

# ── SUPABASE (Frontend — pode ser pública) ────────────────────
# Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.SUA_ANON_KEY_AQUI

# ── SUPABASE (Backend — SECRETA, nunca exposta ao navegador) ──
# Supabase Dashboard → Settings → API → service_role (clique em "Reveal")
# Usada APENAS nas Vercel Functions (/api/create-pix, /api/webhook)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.SUA_SERVICE_ROLE_KEY_AQUI

# ── MERCADO PAGO (Backend — SECRETA) ───────────────────────────
# Mercado Pago → Seu negócio → Configurações → Credenciais de produção
MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-00000000000000000000000000000000-000000000

# ── MERCADO PAGO WEBHOOK SECRET ────────────────────────────────
# Mercado Pago → Suas integrações → [sua aplicação] → Webhooks → Chave secreta
# CRÍTICO para segurança — sem isso, qualquer um pode forjar pagamentos
MP_WEBHOOK_SECRET=sua_chave_secreta_do_webhook_aqui

# ── URL PÚBLICA DO SEU APP ─────────────────────────────────────
# Usada para montar a notification_url do Mercado Pago
PUBLIC_APP_URL=https://seu-dominio.vercel.app

# ── PAINEL ADMIN (Fase 5 — proteção da rota /admin) ────────────
# Acesso via: seudominio.com/admin?key=ESTE_VALOR
# Troque por algo longo e aleatório
VITE_ADMIN_PANEL_KEY=troque_por_uma_chave_longa_e_aleatoria_aqui
